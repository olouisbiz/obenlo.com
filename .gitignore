# Ignore everything in wp-content
/*

# But not the themes and plugins directories
!/themes/
!/plugins/

# Ignore everything inside themes
/themes/*
# But not our custom theme
!/themes/obenlo/

# Ignore everything inside plugins
/plugins/*
!/plugins/obenlo-booking/
!/plugins/obenlo-i18n/
!/plugins/obenlo-pwa/
!/plugins/obenlo-seo/
!/plugins/obenlo-social/

# Documentation and Project Files
!/README.md
!/CHANGELOG.md
!/obenlo-business.md
!/OBENLO_BUSINESS_OVERVIEW.md
!/deployment-guide.md
!/obenlo_listing_logic.md
!/obenlo_profile_logic.md
!/obenlo_chatgpt_prompts.md
!/sync.ps1
!/.gitignore

# Development Files
/node_modules/
.DS_Store
Thumbs.db

# Ignore zip files
*.zip
