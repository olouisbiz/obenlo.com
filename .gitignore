# Obenlo Platform: Git Exclusion Rules
# Core Policy: Ignore all of wp-content except custom Obenlo assets.

/*

# ─── Themes ──────────────────────────────────────────────────────────────────
!/themes/
/themes/*
!/themes/obenlo/

# ─── Plugins ─────────────────────────────────────────────────────────────────
!/plugins/
/plugins/*
!/plugins/obenlo-booking/
!/plugins/obenlo-i18n/
!/plugins/obenlo-pwa/
!/plugins/obenlo-seo/
!/plugins/obenlo-social/

# Ignore vendor and node modules inside plugins (manage via composer/npm)
**/node_modules/
**/vendor/

# ─── Documentation & Project Metadata ────────────────────────────────────────
!/docs/
!/README.md
!/CHANGELOG.md
!/.gitignore
!/sync.ps1

# ─── System & IDE Artifacts ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
*.bak
*.swp
*.zip

# AI/Agent Memory
.gemini/
.antigravity/
